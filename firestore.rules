
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow any authenticated user to read/write for now to bypass complex UID checks and support Admin Panel sync
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // fallback for contact inquiries (public)
    match /contactInquiries/{inquiryId} {
      allow create: if true;
    }
  }
}
