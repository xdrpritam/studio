
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Proto-ready security: Allow all authenticated users to read and write all collections.
    // This supports global collectionGroup queries used in the Admin Terminal.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Support public contact inquiries
    match /contactInquiries/{inquiryId} {
      allow create: if true;
    }
  }
}
