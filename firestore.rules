
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for common security checks
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'gKJKDmDMZmg8RvUT119XStZ7Xpt1' || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // SYSTEM-WIDE ADMIN OVERRIDE
    // Grant administrators full read/write access to all collections and documents.
    // This is required for recursive searches and collection group queries in the dashboard.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // USER-SPECIFIC RULES
    // Allows users to manage their own profile and unblock requests.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /unblockRequests/{requestId} {
        allow read, write: if isOwner(userId);
      }
      
      match /payments/{paymentId} {
        allow read, write: if isOwner(userId);
      }

      match /subscriptions/{subscriptionId} {
        allow read, write: if isOwner(userId);
      }
    }

    // PUBLIC/USER-ACCESSIBLE UTILITIES
    match /redeemCodes/{codeId} {
      allow get: if isSignedIn();
      // Allow users to update code usage status during redemption
      allow update: if isSignedIn();
    }

    match /contactInquiries/{inquiryId} {
      // Allow anyone to submit a contact form
      allow create: if true;
    }

    match /roles_admin/{uid} {
      // Allow users to check their own admin status
      allow read: if isSignedIn();
    }
  }
}
