rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && (request.auth.uid == 'gKJKDmDMZmg8RvUT119XStZ7Xpt1' || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))); }

    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
      
      match /unblockRequests/{requestId} {
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
      }
      
      match /payments/{paymentId} {
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /subscriptions/{subscriptionId} {
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /redeemCodes/{codeId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /contactInquiries/{inquiryId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
    }
  }
}
