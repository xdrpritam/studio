
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.uid == 'gKJKDmDMZmg8RvUT119XStZ7Xpt1'
      );
    }

    // GLOBAL OVERRIDE: Admin UID has full access to EVERYTHING
    // This allows collectionGroup queries for admins.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Standard Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);

      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId);
      }

      match /unblockRequests/{unblockRequestId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
      }

      match /payments/{paymentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
      }
    }

    match /contactInquiries/{inquiryId} {
      allow create: if true;
      allow list, read, update, delete: if isAdmin();
    }
    
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
    }
  }
}
