rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UNMAC SECURITY RULES
     * 
     * Core Philosophy:
     * Strict User-Ownership for standard data, with full override for Admins.
     * Supports Collection Group queries for administrative oversight.
     * 
     * Hardcoded Admin: UkGf3zzd3NdY0XzDhMyV1JbUi0X2
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.uid == 'UkGf3zzd3NdY0XzDhMyV1JbUi0X2'
      );
    }

    // Used for update/delete to ensure the document exists and the requester owns it
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    // --- Collection Group Rules (Required for Admin Dashboard) ---
    
    match /{path=**}/unblockRequests/{unblockRequestId} {
      allow read: if isAdmin();
    }

    // --- Standard Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) || isExistingAdmin();
      allow delete: if isExistingAdmin();

      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isAdmin();
      }

      match /unblockRequests/{unblockRequestId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isAdmin();
      }

      match /payments/{paymentId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) 
                      && request.resource.data.userId == userId;
        allow update, delete: if isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list, create, update, delete: if false; 
    }

    match /contactInquiries/{inquiryId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }
  }
}