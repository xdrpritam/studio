
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for common security checks
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Core Admin logic - split for rules engine optimization
    function isPrimaryAdmin() {
      return isSignedIn() && request.auth.uid == 'gKJKDmDMZmg8RvUT119XStZ7Xpt1';
    }
    
    function isDbAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // SYSTEM-WIDE ADMIN OVERRIDE
    // Split into two allow statements to help the rules engine prove query safety
    // for collection group 'list' operations on the root documents.
    match /{document=**} {
      allow read, write: if isPrimaryAdmin();
      allow read, write: if isDbAdmin();
    }

    // USER-SPECIFIC RULES
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /unblockRequests/{requestId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /payments/{paymentId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /subscriptions/{subscriptionId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // PUBLIC/USER-ACCESSIBLE UTILITIES
    match /redeemCodes/{codeId} {
      allow get: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /contactInquiries/{inquiryId} {
      allow create: if true;
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
    }
  }
}
