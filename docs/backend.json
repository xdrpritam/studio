
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the UnMac service.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "hasUsedTrial": { "type": "boolean" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "UnblockRequest": {
      "title": "UnblockRequest",
      "description": "Details of a user's request to unblock a MAC address.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "macAddress": { "type": "string" },
        "deviceName": { "type": "string" },
        "wifiProvider": { "type": "string" },
        "wifiName": { "type": "string" },
        "requestDate": { "type": "string", "format": "date-time" },
        "expirationDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Unblocked", "Expired"] },
        "subscriptionId": { "type": "string" },
        "unblockedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "macAddress", "wifiProvider", "requestDate", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Represents a transaction for the UnMac service.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "requestId": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Completed", "Failed"] },
        "paymentMethod": { "type": "string", "enum": ["UPI", "VOUCHER"] },
        "transactionId": { "type": "string" },
        "upiApp": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "status", "paymentMethod"]
    },
    "RedeemCode": {
      "title": "RedeemCode",
      "description": "A voucher code that can be used to activate premium access.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "planType": { "type": "string" },
        "isUsed": { "type": "boolean" },
        "multiUse": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "planType", "isUsed", "multiUse", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profile information."
    },
    "/users/{userId}/unblockRequests/{requestId}": {
      "schema": { "$ref": "#/entities/UnblockRequest" },
      "description": "Stores MAC unblock requests."
    },
    "/users/{userId}/payments/{paymentId}": {
      "schema": { "$ref": "#/entities/Payment" },
      "description": "Stores user payment history."
    },
    "/redeemCodes/{codeId}": {
      "schema": { "$ref": "#/entities/RedeemCode" },
      "description": "Stores active voucher codes."
    },
    "/activeMacs/{macAddress}": {
      "description": "Global registry to prevent duplicate active sessions for the same hardware."
    },
    "/trialedMacs/{macAddress}": {
      "description": "Global registry to prevent hardware-level trial abuse."
    }
  }
}
