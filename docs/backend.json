
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the UnMac service.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "UnblockRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UnblockRequest",
      "type": "object",
      "description": "Details of a user's request to unblock a MAC address.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "macAddress": { "type": "string" },
        "deviceName": { "type": "string" },
        "wifiProvider": { "type": "string" },
        "wifiName": { "type": "string" },
        "requestDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "planType": { "type": "string" }
      },
      "required": ["id", "userId", "macAddress", "wifiProvider", "requestDate", "status", "planType"]
    },
    "RedeemCode": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RedeemCode",
      "type": "object",
      "description": "A voucher code that can be used to activate premium access.",
      "properties": {
        "id": { "type": "string" },
        "planType": { "type": "string" },
        "isUsed": { "type": "boolean" },
        "multiUse": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "planType", "isUsed", "multiUse", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profile information."
        }
      },
      {
        "path": "/users/{userId}/unblockRequests/{requestId}",
        "definition": {
          "entityName": "UnblockRequest",
          "schema": { "$ref": "#/backend/entities/UnblockRequest" },
          "description": "Stores MAC unblock requests."
        }
      },
      {
        "path": "/redeemCodes/{codeId}",
        "definition": {
          "entityName": "RedeemCode",
          "schema": { "$ref": "#/backend/entities/RedeemCode" },
          "description": "Stores active voucher codes."
        }
      }
    ]
  }
}
